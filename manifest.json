{
   "action": {
      "default_icon": {
         "128": "images/icon128.png",
         "16": "images/icon16.png",
         "48": "images/icon48.png"
      },
      "default_popup": "popup.html"
   },
   "background": {
      "service_worker": "background.js"
   },
   "content_scripts": [ {
      "js": [ "inject.js" ],
      "matches": [ "*://*.gmgn.ai/*", "*://gmgn.ai/*" ],
      "run_at": "document_start",
      "world": "MAIN"
   }, {
      "js": [ "content.js" ],
      "matches": [ "*://*.gmgn.ai/*", "*://gmgn.ai/*" ],
      "run_at": "document_start"
   } ],
   "description": "本地配置的 GMGN 行情与钱包语音提醒工具，Azure Key 仅保存在本机 Chrome storage",
   "host_permissions": [ "*://*.gmgn.ai/*", "*://gmgn.ai/*", "https://*.tts.speech.microsoft.com/*" ],
   "icons": {
      "128": "images/icon128.png",
      "16": "images/icon16.png",
      "48": "images/icon48.png"
   },
   "manifest_version": 3,
   "name": "行情语音助手",
   "permissions": [ "storage", "unlimitedStorage" ],
   "version": "1.7.4",
   "web_accessible_resources": [ {
      "matches": [ "*://*.gmgn.ai/*", "*://gmgn.ai/*" ],
      "resources": [ "inject.js", "sounds/default.MP3", "sounds/preset1.MP3", "sounds/alert1.MP3", "sounds/alert2.MP3", "sounds/alert3.MP3" ]
   } ]
}
